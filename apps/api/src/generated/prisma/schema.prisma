// npx prisma studio > http://localhost:5555/

// export $(cat .env | xargs) && npx prisma generate

datasource db {
  provider = "postgresql"
}

generator client {
  provider     = "prisma-client-js"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

model Gender {
  id          String   @id @default(uuid())
  title       String
  acronym     String   @unique
  description String?
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relação: Um gênero pode estar em várias pessoas
  people Person[]

  @@map("genders") // Nome da tabela no banco (em minúsculo/plural)
}

model Sexuality {
  id          String   @id @default(uuid())
  title       String
  acronym     String   @unique
  description String?
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  people Person[]

  @@map("sexualities")
}

model Person {
  id         String   @id @default(uuid())
  civilName  String
  socialName String?
  slug       String   @unique
  cpf        String   @unique
  rg         String   @unique
  birthDate  DateTime
  pronouns   String // No banco salva como string (o Enum do TS ajuda na lógica)

  // Chaves estrangeiras
  genderId    String
  sexualityId String

  // Relacionamentos para o Prisma entender a conexão
  gender    Gender    @relation(fields: [genderId], references: [id])
  sexuality Sexuality @relation(fields: [sexualityId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("people")
}
